{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "cdp-devtools": {
      "command": [
        "npx",
        "-y",
        "cdp-tools-mcp@latest"
      ],
      "enabled": false,
      "type": "local"
    },
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ],
      "enabled": true,
      "type": "local"
    },
    "openpencil": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:3100/mcp"
    },
    "penpot": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:4401/mcp"
    },
    "predictradar": {
      "enabled": true,
      "headers": {
        "X-API-Key": "pr_public_predictradar"
      },
      "type": "remote",
      "url": "https://api.predictradar.ai/api/mcp/v2"
    }
  },
  "permission": {
    "external_directory": {
      "/tmp/**": "allow"
    }
  },
  "plugin": [
    "@different-ai/opencode-browser"
  ],
  "provider": {
    "rehdasu": {
      "models": {
        "gpt-5.5": {
          "name": "gpt-5.5"
        }
      },
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "sk-59631ef75950048aa54700b7f6990bcc3fe65d7aa7380c6e9ab9e49068466b2d",
        "baseURL": "https://rehdasu.cn"
      }
    },
    "taobao": {
      "models": {
        "gemini-3.1-pro-preview": {
          "name": "gemini-3.1-pro-preview"
        }
      },
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "sk-x8kiWsJv9t4iJ2aF77p6CjESgO8lATWZ58anKklfp94hMjUz",
        "baseURL": "https://api.vectorengine.ai/v1"
      }
    },
    "xiaomi": {
      "models": {
        "mimo-v2.5-pro": {
          "name": "mimo-v2.5-pro"
        }
      },
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "tp-cg4xk9dqswsj3c048y9da7u2rm66xcl4cwgxoix9hv9owdmq",
        "baseURL": "https://token-plan-cn.xiaomimimo.com/v1"
      }
    },
    "yescode": {
      "models": {
        "claude-sonnet-4-5-20250929": {
          "name": "Claude Sonnet 4.5"
        }
      },
      "options": {
        "baseURL": "https://co.yes.vg",
        "name": "YesCode",
        "npm": "@ai-sdk/openai-compatible"
      }
    }
  }
}